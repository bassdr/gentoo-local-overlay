diff --git a/libretro-build.sh b/libretro-build.sh
index 717af8ef..01b0b578 100755
--- a/libretro-build.sh
+++ b/libretro-build.sh
@@ -142,6 +142,8 @@ build_default_cores_libretro_gl() {
 	if [ $platform != "psp1" ]; then
 		libretro_build_core 3dengine
 	fi
+
+	libretro_build_core mednafen_psx_hw
 }
 
