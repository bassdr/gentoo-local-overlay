diff --git a/build-config.sh b/build-config.sh
index 9cc03747..1db2a128 100644
--- a/build-config.sh
+++ b/build-config.sh
@@ -90,6 +90,7 @@ include_core_vice_xvic
 include_core_vice_xplus4
 # --- PlayStation1 emulator cores ---
 include_core_mednafen_psx
