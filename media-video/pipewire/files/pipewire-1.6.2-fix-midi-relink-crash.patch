Fix crash in alsa-seq-bridge when MIDI device is disconnected.

free_port() zeroes the port struct (including mix_link) without first
removing the port from stream->mix_list. Meanwhile, process_read() on
the data loop thread iterates mix_list via spa_list_for_each, hitting
the zeroed-out list pointers and crashing with SIGSEGV.

The mix_list is only safe to modify from the data loop thread (as
do_port_set_io already does via spa_loop_locked). Add the same
synchronization to free_port: use spa_loop_locked to remove the port
from mix_list on the data loop before zeroing the struct.

--- a/spa/plugins/alsa/alsa-seq-bridge.c
+++ b/spa/plugins/alsa/alsa-seq-bridge.c
@@ -385,10 +385,32 @@
 	return port;
 }

+struct free_port_info {
+	struct seq_state *state;
+	struct seq_port *port;
+};
+
+static int do_free_port_mix(struct spa_loop *loop, bool async, uint32_t seq,
+		const void *data, size_t size, void *user_data)
+{
+	struct free_port_info *info = user_data;
+	struct seq_port *port = info->port;
+
+	if (port->mixing) {
+		spa_list_remove(&port->mix_link);
+		port->mixing = false;
+	}
+	return 0;
+}
+
 static void free_port(struct seq_state *state, struct seq_stream *stream, struct seq_port *port)
 {
+	struct free_port_info info = { .state = state, .port = port };
+
 	stream->ports[port->id] = NULL;
 	spa_list_remove(&port->link);
+	spa_loop_locked(state->data_loop, do_free_port_mix,
+			SPA_ID_INVALID, NULL, 0, &info);

 	spa_node_emit_port_info(&state->hooks,
 			port->direction, port->id, NULL);
